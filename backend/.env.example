APP_NAME="Bike Marketplace"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=bike_marketplace
DB_USERNAME=bike_user
DB_PASSWORD=bike_password

# JWT Secret Key (Replace with secure random string in production)
# You can generate: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_TIME=15

# Refresh Token (in minutes, 7 days = 10080)
REFRESH_TOKEN_EXPIRATION_TIME=10080

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost

# Mail Configuration (for password reset emails)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@bike-marketplace.local
MAIL_FROM_NAME="${APP_NAME}"
